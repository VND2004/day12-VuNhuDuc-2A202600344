# Copy thành .env và điền giá trị thật
# KHONG commit file .env len Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security
AGENT_API_KEY=dev-key-change-me-in-production

# Rate & Budget (Part 6)
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
MAX_HISTORY_MESSAGES=20
HISTORY_TTL_SECONDS=2764800

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
